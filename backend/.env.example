# MongoDB Connection String
# Local: mongodb://localhost:27017/tulip_crm
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/crm_db
MONGODB_URI=mongodb://localhost:27017/tulip_crm

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Gemini AI (for Knowledge Base)
GEMINI_API_KEY=your-gemini-api-key

# Application Settings
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
LOG_LEVEL=DEBUG

# Default Admin Credentials (REQUIRED - app will fail to start without these)
DEFAULT_ADMIN_EMAIL=admin@tulip.com
DEFAULT_ADMIN_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DEFAULT_ADMIN_NAME=Admin User

# Super Admin Credentials (REQUIRED - app will fail to start without these)
DEFAULT_SUPER_ADMIN_EMAIL=superadmin@crm.com
DEFAULT_SUPER_ADMIN_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DEFAULT_SUPER_ADMIN_NAME=Super Admin
